{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-python",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "static-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "3000", "."],
      "port": 3000
    }
  ]
}
